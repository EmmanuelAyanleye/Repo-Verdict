# Optional: OpenAI API key for enhanced semantic analysis
# If not provided, RepoVerdict falls back to keyword-based analysis.
OPENAI_API_KEY=

# Optional: GitHub personal access token to raise API rate limits
# If not provided, unauthenticated rate limits apply (60 requests/hour).
GITHUB_TOKEN=

# Optional: set to False only when deploying behind a proper host/static setup.
DEBUG=True
